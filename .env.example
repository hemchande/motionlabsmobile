# Athlete Coach API (FastAPI)
# Production: https://athlete-coach-fastapi-630016859450.europe-west1.run.app
# Local dev: http://localhost:8004
# If not set, uses same host as page with port 8004
VITE_ATHLETE_COACH_API_URL=https://athlete-coach-fastapi-630016859450.europe-west1.run.app

# Live Camera WebSocket (for real-time pose estimation)
# If not set, defaults to ws://136.115.36.127:8010/api/live-camera/ws
VITE_LIVE_CAMERA_WS_URL=ws://136.115.36.127:8010/api/live-camera/ws

# Stream video (optional)
VITE_STREAM_API_KEY=
VITE_STREAM_API_SECRET=
VITE_STREAM_CALL_ID=

# Other services (optional)
VITE_AGENT_SERVICE_URL=http://localhost:3001
VITE_MCP_SERVICE_URL=http://localhost:8004
VITE_BREVO_API_KEY=
