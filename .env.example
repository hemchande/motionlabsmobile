# Athlete Coach API (FastAPI)
# Production: https://athlete-coach-fastapi-630016859450.europe-west1.run.app
# Local dev: http://localhost:8004
# If not set, uses same host as page with port 8004
VITE_ATHLETE_COACH_API_URL=https://athlete-coach-fastapi-630016859450.europe-west1.run.app

# Live Camera WebSocket (pose + metrics on port 8010)
# Can be: (1) base URL e.g. http://localhost:8010 → client builds ws://localhost:8010/api/live-camera/ws,
#         (2) full URL e.g. ws://localhost:8010/api/live-camera/ws or wss://live-camera-xxx.run.app/api/live-camera/ws.
# Optional query: ?athlete_id=...&athlete_name=... for segment labelling when face is unknown.
VITE_LIVE_CAMERA_WS_URL=http://localhost:8010

# Stream video (optional)
VITE_STREAM_API_KEY=
VITE_STREAM_API_SECRET=
VITE_STREAM_CALL_ID=

# Other services (optional)
VITE_AGENT_SERVICE_URL=http://localhost:3001
VITE_MCP_SERVICE_URL=http://localhost:8004
VITE_BREVO_API_KEY=
